{
  "name": "rebuilding-iran-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:data; next build",
    "build:data": "node scripts/build-quizzes.js; node scripts/build-flashcards.js; node scripts/build-search-index.js; node scripts/build-farsi-vocab.js; echo 'Data build step done'",
    "build:search": "node scripts/build-search-index.js",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:engine": "vitest run game/engine"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "js-yaml": "^4.1.1",
    "lunr": "^2.3.9",
    "next": "^16.1.6",
    "openai": "^6.22.0",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "unified": "^11.0.5",
    "yaml": "^2.8.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@types/lunr": "^2.3.7",
    "@types/node": "^20.17.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  }
